  <!-- Mirror the build output into the ExodAI deploy folder so the EDOPro
       client always launches the freshly built WindBot. Override the path
       with the EXODAI_DEPLOY_DIR env var. Only .exe/.dll/.config/.pdb are
       copied — data files like cards.cdb in the deploy folder are left
       untouched. The step no-ops silently if the deploy folder doesn't
       exist (e.g. on CI). -->
  <Target Name="DeployToExodAI" AfterTargets="Build">
    <PropertyGroup>
      <ExodAIDeployDir Condition="'$(EXODAI_DEPLOY_DIR)' != ''">$(EXODAI_DEPLOY_DIR)</ExodAIDeployDir>
      <ExodAIDeployDir Condition="'$(ExodAIDeployDir)' == ''">C:\Users\Joe\Documents\ExodAI\src\deploy\windbot-bin</ExodAIDeployDir>
    </PropertyGroup>
    <!-- Kill any running WindBot.exe so Copy doesn't hit a file-lock error
         from a stale instance left over by a previous EDOPro session.
         The /T flag also kills child processes. -ErrorAction SilentlyContinue
         keeps the build green when no instance is running. -->
    <Exec
      Command="taskkill /F /IM WindBot.exe /T &gt;nul 2&gt;&amp;1"
      IgnoreExitCode="true"
      Condition="Exists('$(ExodAIDeployDir)')" />
    <ItemGroup>
      <ExodAIDeployFiles Include="$(TargetDir)*.exe;$(TargetDir)*.dll;$(TargetDir)*.config;$(TargetDir)*.pdb" />
    </ItemGroup>
    <Copy
      SourceFiles="@(ExodAIDeployFiles)"
      DestinationFolder="$(ExodAIDeployDir)"
      SkipUnchangedFiles="true"
      Condition="Exists('$(ExodAIDeployDir)')" />
    <Message Importance="high" Text="Deployed WindBot to $(ExodAIDeployDir)" Condition="Exists('$(ExodAIDeployDir)')" />
    <Message Importance="high" Text="Skipped deploy: $(ExodAIDeployDir) does not exist" Condition="!Exists('$(ExodAIDeployDir)')" />
  </Target>
